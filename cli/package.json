{
  "name": "@tzusman/aros",
  "version": "0.1.0",
  "description": "AROS — Agent Review Orchestration Service",
  "type": "module",
  "bin": {
    "aros": "./dist/index.js"
  },
  "files": [
    "dist"
  ],

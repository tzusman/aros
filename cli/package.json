    "commander": "^13.0.0",
    "express": "^5.1.0",
    "mime-types": "^2.1.35",
    "picocolors": "^1.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@aros/mcp": "workspace:*",
    "@aros/server": "workspace:*",
    "@aros/types": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
